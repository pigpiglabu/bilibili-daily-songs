{
  "manifest_version": 3,
  "name": "B站 AI 每日歌单推荐",
  "description": "根据用户喜好在 B 站每日生成 10 首歌曲视频推荐。",
  "version": "1.0.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.bilibili.com/*",
    "https://www.bilibili.com/*"
  ],
  "action": {
    "default_title": "AI 每日歌单",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.bilibili.com/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
